# setup-vps defaults
VPS_MODE="latest" # latest|frozen
VPS_DEFAULT_SSH_PORT="22"
VPS_DEFAULT_PACKAGES="zsh,git,curl,tmux,ripgrep,fd-find,bat,fzf,zoxide,htop"
VPS_MIN_NEOVIM_VERSION="0.11.0"
VPS_PINNED_NEOVIM_TAG="v0.11.0" # used when mode=frozen
VPS_OH_MY_ZSH_REF="master"
VPS_USE_UFW="1"
VPS_USE_UNATTENDED_UPGRADES="1"
VPS_USE_FAIL2BAN="0"
VPS_DISABLE_ROOT_SSH="1"
VPS_DISABLE_PASSWORD_AUTH="1"
VPS_RUN_DOTFILES="1"
VPS_USE_STATE="1"
VPS_RETRY_ATTEMPTS="3"
VPS_RETRY_DELAY_SECONDS="2"
