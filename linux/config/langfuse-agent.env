# setup-langfuse-agent defaults
LANGFUSE_MODE="latest"                 # latest|frozen
LANGFUSE_WORKSPACE_SUBDIR="langfuse"
LANGFUSE_NODE_VERSION="24"
LANGFUSE_PNPM_VERSION="9.5.0"
LANGFUSE_PYTHON_PREFIX="3.14"
LANGFUSE_PINNED_PYTHON_VERSION="3.14.0" # used when mode=frozen
LANGFUSE_GIT_NAME="hasibspot"
LANGFUSE_GIT_EMAIL="hasibspot@placeholder.invalid"
LANGFUSE_GITHUB_USER="hasibspot"
LANGFUSE_GITHUB_HOST="github.com"
# Optional token source for gh auth:
# LANGFUSE_GITHUB_TOKEN_FILE="/home/<user>/.config/setup-langfuse/gh-token"
LANGFUSE_RUN_MAIN_DX="0"
LANGFUSE_USE_STATE="1"
LANGFUSE_RETRY_ATTEMPTS="3"
LANGFUSE_RETRY_DELAY_SECONDS="2"
